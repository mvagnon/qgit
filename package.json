{
  "name": "zapgit",
  "version": "0.1.0",
  "description": "Fast, precise git chores from your terminal.",
  "type": "module",
  "bin": {
    "zapgit": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "git",
    "cli",
    "commit",
    "conventional-commits",
    "ollama",
    "llm",
    "ai",
    "bun"
  ],
  "author": "Matthieu Vagnon <hi@mvagnon.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mvagnon/zapgit.git"
  },
  "homepage": "https://github.com/mvagnon/zapgit#readme",
  "bugs": {
    "url": "https://github.com/mvagnon/zapgit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "zapgit": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir dist",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "citty": "^0.2.2",
    "ollama": "^0.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@types/bun": "^1.3.14",
    "eslint": "^10.6.0",
    "jiti": "^2.7.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
